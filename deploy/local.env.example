# Template for deploy/local.env (which is gitignored). Copy to deploy/local.env
# and fill in YOUR hosts. These site-specific values must never be committed;
# tracked code/docs stay generic and read them from the environment.
export COLUMBO_BUILDER="user@docker-host"                 # amd64 docker host (build + save image)
export COLUMBO_NODES="user@k3s-node-1 user@k3s-node-2"    # k3s nodes (ctr import targets)
export COLUMBO_OLLAMA="http://ollama-host:11434"          # Ollama host for --dedup=embed / --llm-probes
